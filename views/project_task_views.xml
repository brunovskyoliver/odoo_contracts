<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="project_task_form_inherit_contract_customer_report" model="ir.ui.view">
        <field name="name">project.task.form.inherit.contract.customer.report</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']/span[@id='end_button_box']" position="before">
                <button
                    name="action_open_customer_report_wizard"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-file-pdf-o"
                    invisible="not project_id"
                >
                    <div class="o_stat_info">
                        <span class="o_stat_text">Customer Report</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
