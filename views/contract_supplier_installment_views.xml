<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="contract_contract_supplier_installment_form_view" model="ir.ui.view">
        <field name="name">contract.contract.supplier.installment.form</field>
        <field name="model">contract.contract</field>
        <field name="inherit_id" ref="contract.contract_contract_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_open_date_update_wizard']" position="after">
                <button
                    name="action_open_supplier_installment_import_wizard"
                    type="object"
                    string="Importovať splátkový kalendár"
                    invisible="not show_supplier_installment_import or is_terminated"
                    groups="account.group_account_invoice"
                />
            </xpath>
            <xpath expr="//field[@name='is_terminated']" position="after">
                <field name="show_supplier_installment_import" invisible="1" />
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page
                    name="supplier_installments"
                    string="Splátkový kalendár"
                    invisible="not show_supplier_installment_import"
                >
                    <field name="supplier_installment_line_ids">
                        <list
                            create="0"
                            edit="0"
                            delete="0"
                            decoration-success="state == 'invoiced'"
                            decoration-warning="state == 'pending'"
                        >
                            <field name="currency_id" column_invisible="True" />
                            <field name="invoice_number" />
                            <field name="delivery_date" />
                            <field name="due_date" />
                            <field name="vat_rate" />
                            <field name="amount_untaxed" widget="monetary" />
                            <field name="amount_tax" widget="monetary" />
                            <field name="amount_total" widget="monetary" />
                            <field name="state" widget="badge" />
                            <field name="invoice_id" />
                            <button
                                name="action_create_bill"
                                string="Vytvoriť faktúru"
                                type="object"
                                invisible="state != 'pending'"
                            />
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
