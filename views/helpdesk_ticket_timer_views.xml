<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="helpdesk_ticket_view_form_timer_timesheets" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.timer.timesheets</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_view_timer_timesheets"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-clock-o"
                    invisible="not timer_timesheet_count"
                >
                    <field name="timer_timesheet_count" widget="statinfo" string="Čas z časovača"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
