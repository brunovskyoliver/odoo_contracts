<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="contract_timer_session_rule_own" model="ir.rule">
        <field name="name">Timer sessions: own sessions</field>
        <field name="model_id" ref="model_contract_timer_session"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="contract_timer_session_rule_manager" model="ir.rule">
        <field name="name">Timer sessions: helpdesk managers</field>
        <field name="model_id" ref="model_contract_timer_session"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('helpdesk.group_helpdesk_manager'))]"/>
    </record>
</odoo>
